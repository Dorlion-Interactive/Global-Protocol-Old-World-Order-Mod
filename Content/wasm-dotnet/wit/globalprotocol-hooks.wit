package globalprotocol:hooks@1.0.0;

interface gp {
    log: func(msg: string);
    country-get-gdp: func(idx: s32) -> f64;
    country-get-treasury: func(idx: s32) -> f64;
    country-get-stability: func(idx: s32) -> f32;
    get-tick: func() -> s32;
    get-year: func() -> s32;
    get-month: func() -> s32;
    add-treasury: func(idx: s32, amount: f32);
    fire-trigger: func(trigger-type: s32, source: s32, target: s32);
    country-set-treasury: func(idx: s32, value: f64);
    country-get-tech-level: func(idx: s32) -> s32;
    show-mod-popup: func(title: string, body: string);
    fire-event: func(idx: s32, id: string);
}

interface mod-hooks {
    on-init: func();
    on-game-tick: func(tick: s32, year: s32, month: s32);
    on-ui-action: func(hook-name: string, mod-id: string);
    on-country-eliminated: func(country-index: s32);
    on-peace-signed: func(proposer-index: s32, target-index: s32);
    on-war-declared: func(attacker-index: s32, defender-index: s32, tick: s32);
    on-tech-researched: func(country-index: s32, tech-index: s32);
    on-building-completed: func(province-index: s32, building-index: s32);
    on-event-fired: func(country-index: s32, event-index: s32);
}

// wit-bindgen generates [UnmanagedCallersOnly] export shims under
// "globalprotocol:hooks/mod-hooks@1.0.0#on-*" which wit-component (inside
// wasm-component-ld) lifts into component-level exports resolved via
// WasmtimeComponentBackend.HookInterfaceExportCandidates[0].
// Imports use [WasmImportLinkage] under module name
// "globalprotocol:hooks/gp@1.0.0" matching GpInstanceExportCandidates[0].
world globalprotocol-mod {
    import gp;
    export mod-hooks;
}
